{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tophhie-cloud-redirect-service",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-01",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "bc9a6d6680c346599ee1023225d66550"
		}
	],
	"routes": [
		{
			"pattern": "aka.tophhie.dev/*",
			"zone_name": "tophhie.dev"
		}
	],
	"workers_dev": false
}